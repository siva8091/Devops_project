/opt/sonar-mcp
 ├── sonarqube-mcp-server.jar
 ├── storage
 └── start-mcp.sh

#!/bin/bash

export SONARQUBE_URL=http://your-sonarqube-server:9000
export SONARQUBE_TOKEN=<initial-admin-token>
export STORAGE_PATH=/opt/sonar-mcp/storage

java -jar sonarqube-mcp-server.jar

chmod +x start-mcp.sh
./start-mcp.sh


{
  "mcpServers": {
    "sonarqube": {
      "url": "http://your-mcp-server:8080",
      "env": {
        "SONAR_HOST_URL": "http://sonarqube.company.com:9000",
        "SONAR_TOKEN": "their-personal-token"
      }
    }
  }
}



#!/bin/bash

# Transport configuration
export SONARQUBE_TRANSPORT=http
export SONARQUBE_HTTP_PORT=8080
export SONARQUBE_HTTP_HOST=0.0.0.0

# SonarQube connection
export SONAR_HOST_URL=http://sonarqube.company.com:9000
export SONAR_TOKEN=your-sonar-token

# MCP storage location
export STORAGE_PATH=/opt/sonar-mcp/storage

# Start MCP server
java -jar sonarqube-mcp-server.jar
